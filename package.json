{
  "name": "argon-coding-agent",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "argon": "./dist/tui/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "tui": "node dist/tui/cli.js",
    "test": "vitest --run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@earendil-works/pi-ai": "^0.74.0",
    "@earendil-works/pi-tui": "^0.74.0",
    "@mariozechner/clipboard": "^0.3.5",
    "proper-lockfile": "^4.1.2",
    "undici": "^7.25.0"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "@types/proper-lockfile": "^4.1.4",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
